---
/**
 * index.astro — The Map
 * This IS the navigation. No hero, no sections, no scrolling.
 * A full-viewport parchment map with clickable named regions.
 */
import Layout from '@/layouts/Layout.astro';

const destinations = [
  {
    label: 'The Cartographer',
    desc: 'The person behind the maps. Background, interests, and direction.',
    href: '/about',
    x: '17%',
    y: '57%',
    cardSide: 'right',
    external: false,
  },
  {
    label: 'The Codex',
    desc: 'An archive of expeditions — projects, research, and experiences.',
    href: '/codex',
    x: '76%',
    y: '44%',
    cardSide: 'left',
    external: false,
  },
  {
    label: 'The Garden',
    desc: 'A space for thinking out loud. Notes, ideas, and works in progress.',
    href: '/garden',
    x: '27%',
    y: '75%',
    cardSide: 'right',
    external: false,
  },
  {
    label: 'The Observatory',
    desc: "What I'm currently building, reading, and thinking about.",
    href: '/now',
    x: '70%',
    y: '29%',
    cardSide: 'left',
    external: false,
  },
  {
    label: 'The Frontier',
    desc: 'The professional record. Where to go if you came here for a resume.',
    href: 'https://linkedin.com/in/yourprofile',
    x: '68%',
    y: '67%',
    cardSide: 'left',
    external: true,
  },
];
---

<Layout
  title="The Cartographer's Study"
  description="Personal site — a world to explore, not a portfolio to scroll."
  variant="map"
>
  <div class="relative w-screen h-screen overflow-hidden bg-parchment select-none" id="map-world">

    <!-- Layer 1: vintage map image, more visible now -->
    <div
      class="absolute inset-0 bg-cover bg-center pointer-events-none"
      style="background-image: url('/maps/old_cool_map.jpg'); opacity: 0.40; filter: sepia(0.3) saturate(0.85) contrast(1.08);"
      aria-hidden="true"
    ></div>

    <!-- Layer 2: second map layer for depth -->
    <div
      class="absolute inset-0 bg-cover pointer-events-none"
      style="background-image: url('/maps/fantasymap2.jpg'); background-position: 70% 40%; opacity: 0.15; filter: sepia(0.7) saturate(0.45); mix-blend-mode: multiply;"
      aria-hidden="true"
    ></div>

    <!-- Layer 2.5: tertiary map for geographic richness -->
    <div
      class="absolute inset-0 bg-cover pointer-events-none"
      style="background-image: url('/maps/fantasymap.jpg'); background-position: 30% 55%; opacity: 0.11; filter: sepia(0.75) saturate(0.35); mix-blend-mode: multiply;"
      aria-hidden="true"
    ></div>

    <!-- Layer 3: primary parchment texture -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: url('/textures/parchment_texture1.jpg'); background-size: 420px 420px; background-repeat: repeat; mix-blend-mode: multiply; opacity: 0.34; filter: sepia(0.25) contrast(1.05);"
      aria-hidden="true"
    ></div>

    <!-- Layer 3.5: secondary texture at different scale and blend -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: url('/textures/parchment_texture2.jpg'); background-size: 280px 280px; background-repeat: repeat; mix-blend-mode: overlay; opacity: 0.18; filter: sepia(0.15) contrast(1.1);"
      aria-hidden="true"
    ></div>

    <!-- Layer 4: radial vignette — edges darken toward parchment-deep -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 75% 70% at center, transparent 25%, rgba(28, 18, 8, 0.34) 100%);"
      aria-hidden="true"
    ></div>

    <!-- ── Edge vignettes — "off the map" darkness toward branch termini ── -->
    <!-- Western edge vignette (Portfolio direction) -->
    <div
      class="absolute inset-y-0 left-0 pointer-events-none hidden md:block"
      style="width: 20%; background: linear-gradient(to right, rgba(28,18,8,0.18), transparent); z-index: 10;"
      aria-hidden="true"
    ></div>
    <!-- Southern edge vignette (Lab direction) -->
    <div
      class="absolute inset-x-0 bottom-0 pointer-events-none hidden md:block"
      style="height: 22%; background: linear-gradient(to top, rgba(28,18,8,0.18), transparent); z-index: 10;"
      aria-hidden="true"
    ></div>

    <!-- ── Cartouche (upper-left, sits on the map like a real label) ────── -->
    <div class="cartouche" style="top: 7%;">
      <p class="cartouche-eyebrow">The Cartographer's Study</p>
      <h1 class="cartouche-name">Your Name</h1>
      <div class="cartouche-rule"></div>
      <p class="cartouche-tagline">Mapping the intellectual frontier</p>
      <!-- Wax seal — stamped onto the bottom-right corner of the border -->
      <img
        src="/accents/postalstamps.avif"
        alt=""
        style="position: absolute; bottom: -22px; right: -18px; width: 60px; opacity: 0.5; filter: sepia(0.6) contrast(1.05); transform: rotate(15deg); mix-blend-mode: multiply; pointer-events: none;"
        aria-hidden="true"
        loading="eager"
      />
    </div>

    <!-- ── Decorative coordinates (aria-hidden) ───────────────────────── -->
    <p
      class="absolute font-display text-gold-pale pointer-events-none"
      style="font-size: 0.45rem; letter-spacing: 0.25em; bottom: 18%; left: 42%; opacity: 0.55;"
      aria-hidden="true"
    >48°32'N · 16°17'E</p>

    <p
      class="absolute font-display text-gold-pale pointer-events-none"
      style="font-size: 0.4rem; letter-spacing: 0.2em; top: 38%; left: 6%; opacity: 0.45; writing-mode: vertical-rl; transform: rotate(180deg);"
      aria-hidden="true"
    >Terra Incognita</p>

    <p
      class="absolute font-display text-gold-pale pointer-events-none"
      style="font-size: 0.4rem; letter-spacing: 0.2em; top: 55%; right: 6%; opacity: 0.4; writing-mode: vertical-rl;"
      aria-hidden="true"
    >Hic Svnt Leones</p>

    <!-- ── Scattered cartographic annotations — empty center of the map ── -->
    <span
      class="absolute font-display pointer-events-none"
      style="top: 43%; left: 46%; font-size: 1.05rem; color: var(--color-gold); opacity: 0.15; transform: rotate(-6deg);"
      aria-hidden="true"
    >✦</span>
    <span
      class="absolute font-display pointer-events-none"
      style="top: 56%; left: 52%; font-size: 0.7rem; color: var(--color-gold); opacity: 0.13; transform: rotate(9deg);"
      aria-hidden="true"
    >✦</span>
    <span
      class="absolute font-display pointer-events-none"
      style="top: 38%; left: 41%; font-size: 0.55rem; color: var(--color-gold); opacity: 0.12; transform: rotate(-14deg);"
      aria-hidden="true"
    >✦</span>
    <span
      class="absolute font-display pointer-events-none"
      style="top: 50%; left: 58%; font-size: 0.65rem; color: var(--color-gold); opacity: 0.14; transform: rotate(4deg);"
      aria-hidden="true"
    >✦</span>

    <!-- ── Stamp accent — top-right corner ───────────────────────────── -->
    <div
      class="absolute top-5 right-5 md:top-8 md:right-8 pointer-events-none"
      aria-hidden="true"
    >
      <img
        src="/accents/postalstamps.avif"
        alt=""
        class="w-14 md:w-18 opacity-30 mix-blend-multiply"
        style="filter: sepia(0.5); transform: rotate(-8deg);"
        loading="eager"
      />
    </div>

    <!-- ── Fantasy creatures and nautical illustrations ─────────────── -->

    <!-- Sea monster — lower-center ocean -->
    <div
      class="absolute pointer-events-none hidden md:block"
      style="left: 49%; top: 80%; transform: translate(-50%, -50%) rotate(-8deg); z-index: 8;"
      aria-hidden="true"
    >
      <img
        src="/accents/nobg/seamonster1-nobg.png"
        alt=""
        style="width: 155px; opacity: 0.5; filter: sepia(0.5) grayscale(0.3) brightness(0.85); mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);"
        loading="eager"
      />
    </div>

    <!-- Dragon — upper center, soaring above the route -->
    <div
      class="absolute pointer-events-none hidden md:block"
      style="left: 54%; top: 13%; transform: translate(-50%, -50%) rotate(-5deg) scaleX(-1); z-index: 8;"
      aria-hidden="true"
    >
      <img
        src="/accents/nobg/dragon1-nobg.png"
        alt=""
        style="width: 148px; opacity: 0.45; filter: sepia(0.5) grayscale(0.3) brightness(0.85); mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);"
        loading="eager"
      />
    </div>

    <!-- Sailing ship — open water below-left of center, away from the route -->
    <div
      class="absolute pointer-events-none hidden md:block"
      style="left: 38%; top: 62%; transform: translate(-50%, -50%) rotate(15deg); z-index: 8;"
      aria-hidden="true"
    >
      <img
        src="/accents/nobg/ship1-nobg.png"
        alt=""
        style="width: 115px; opacity: 0.45; filter: sepia(0.5) grayscale(0.3) brightness(0.85); mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);"
        loading="eager"
      />
    </div>

    <!-- Small sea creature — lower-left corner -->
    <div
      class="absolute pointer-events-none hidden md:block"
      style="left: 9%; top: 79%; transform: translate(-50%, -50%) rotate(14deg); z-index: 8;"
      aria-hidden="true"
    >
      <img
        src="/accents/nobg/seamonster3-nobg.png"
        alt=""
        style="width: 88px; opacity: 0.45; filter: sepia(0.5) grayscale(0.3) brightness(0.85); mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);"
        loading="eager"
      />
    </div>

    <!-- Creature — upper-right open water -->
    <div
      class="absolute pointer-events-none hidden md:block"
      style="left: 84%; top: 20%; transform: translate(-50%, -50%) rotate(-5deg); z-index: 8;"
      aria-hidden="true"
    >
      <img
        src="/accents/nobg/seamonster4-nobg.png"
        alt=""
        style="width: 80px; opacity: 0.45; filter: sepia(0.5) grayscale(0.3) brightness(0.85); mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);"
        loading="eager"
      />
    </div>

    <!-- "Hic Svnt Dracones" annotation — open water between route legs -->
    <p
      class="absolute pointer-events-none font-display hidden md:block"
      style="left: 57%; top: 60%; transform: translate(-50%, -50%) rotate(-2deg); font-size: 0.48rem; letter-spacing: 0.32em; color: var(--color-ink); opacity: 0.11; text-transform: uppercase; white-space: nowrap; z-index: 8;"
      aria-hidden="true"
    >Hic Svnt Dracones</p>

    <!-- ── Expedition route path ──────────────────────────────────────── -->
    <svg
      class="absolute inset-0 w-full h-full pointer-events-none hidden md:block"
      viewBox="0 0 100 100"
      preserveAspectRatio="none"
      overflow="visible"
      aria-hidden="true"
      style="z-index: 12;"
    >
      <!-- Path 1: ghost layer — always visible, aged and faded beneath the main route -->
      <!-- d= is IDENTICAL to the main route so it traces the same course -->
      <path
        d="M 17,57 C 8,65 14,82 27,75 C 38,72 50,68 52,55 C 54,42 60,22 70,29 C 76,30 86,36 76,44 C 72,56 66,64 68,67"
        fill="none"
        stroke="#8B1A1A"
        stroke-width="1.5"
        stroke-dasharray="4 8"
        stroke-linecap="round"
        opacity="0.35"
        vector-effect="non-scaling-stroke"
      />
      <!-- Path 2: main route with mid-voyage detour, drawn on page load via JS -->
      <path
        id="route-draw"
        d="M 17,57 C 8,65 14,82 27,75 C 38,72 50,68 52,55 C 54,42 60,22 70,29 C 76,30 86,36 76,44 C 72,56 66,64 68,67"
        fill="none"
        stroke="#8B1A1A"
        stroke-width="2.5"
        stroke-linecap="round"
        opacity="0.9"
        vector-effect="non-scaling-stroke"
      />
      <!-- Branch 1: Portfolio — exits the western edge of the map -->
      <path
        id="branch-portfolio"
        d="M 17,57 C 12,50 5,41 -2,35"
        fill="none"
        stroke="#8B1A1A"
        stroke-width="1.5"
        stroke-dasharray="4 6"
        stroke-linecap="round"
        opacity="0.7"
        vector-effect="non-scaling-stroke"
      />
      <!-- Branch 2: Lab — exits the southern edge of the map -->
      <path
        id="branch-lab"
        d="M 27,75 C 25,83 22,91 20,102"
        fill="none"
        stroke="#8B1A1A"
        stroke-width="1.5"
        stroke-dasharray="4 6"
        stroke-linecap="round"
        opacity="0.7"
        vector-effect="non-scaling-stroke"
      />
      <!-- Arrowhead: Portfolio terminus — pointing west, right at the edge -->
      <polygon
        class="branch-arrowhead"
        points="0.5,35 4,32.5 4,37.5"
        fill="#8B1A1A"
        opacity="0.85"
        vector-effect="non-scaling-stroke"
      />
      <!-- Arrowhead: Lab terminus — pointing south, right at the bottom edge -->
      <polygon
        class="branch-arrowhead"
        points="20,100 17.5,96.5 22.5,96.5"
        fill="#8B1A1A"
        opacity="0.85"
        vector-effect="non-scaling-stroke"
      />
    </svg>

    <!-- ── Desktop: Expedition destination markers ─────────────────────── -->
    <div class="hidden md:block" aria-label="Map navigation">
      {destinations.map(({ label, desc, href, x, y, cardSide, external }) => (
        <div
          class="map-marker"
          style={`left: ${x}; top: ${y};`}
          data-card-side={cardSide}
        >
          <a
            href={href}
            class="marker-body"
            aria-label={label}
            {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            <svg
              class="marker-svg"
              width="44"
              height="44"
              viewBox="0 0 44 44"
              fill="none"
              aria-hidden="true"
            >
              <circle class="marker-halo" cx="22" cy="22" r="18" fill="none" stroke="#8B6914" stroke-width="0.75" opacity="0.4"/>
              <circle cx="22" cy="22" r="13" fill="none" stroke="#8B6914" stroke-width="1.5" opacity="0.9"/>
              <circle cx="22" cy="22" r="7" fill="#A01E1E"/>
            </svg>
            <span class="marker-label">{label}</span>
          </a>
          <div class="marker-card" aria-hidden="true">
            <strong class="marker-card-title">{label}</strong>
            <p class="marker-card-desc">{desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- ── Branch end markers — external expeditions, at map edges ─────── -->
    <div class="hidden md:block">
      <!-- Portfolio branch terminus — right at the western edge -->
      <div class="branch-marker" style="left: 1%; top: 35%;">
        <a
          href="https://mp0549.github.io/my-portfolio/"
          class="branch-body"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="The Portfolio"
        >
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="10" fill="none" stroke="#8B6914" stroke-width="1" opacity="0.7"/>
            <circle cx="14" cy="14" r="4.5" fill="#A01E1E" opacity="0.85"/>
          </svg>
          <span class="branch-label">THE PORTFOLIO ›</span>
          <span class="branch-subtitle">Beyond the western reach</span>
        </a>
      </div>
      <!-- Lab branch terminus — right at the southern edge -->
      <div class="branch-marker branch-marker--south" style="left: 18%; top: 92%;">
        <a
          href="https://mp0549.github.io/lab/"
          class="branch-body"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="The Lab"
        >
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <circle cx="14" cy="14" r="10" fill="none" stroke="#8B6914" stroke-width="1" opacity="0.7"/>
            <circle cx="14" cy="14" r="4.5" fill="#A01E1E" opacity="0.85"/>
          </svg>
          <span class="branch-label">THE LAB ↓</span>
          <span class="branch-subtitle">Into the experimental deep</span>
        </a>
      </div>
    </div>

    <!-- ── Mobile: Vertical destination list ─────────────────────────── -->
    <nav
      class="md:hidden absolute left-0 right-0 flex flex-col items-center gap-3 px-8"
      style="top: 48%;"
      aria-label="Navigation"
    >
      {destinations.map(({ label, desc, href, external }) => (
        <a
          href={href}
          class="map-mobile-link w-full max-w-xs text-center"
          {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {label}
          <small>{desc}</small>
        </a>
      ))}
    </nav>

    <!-- ── Compass rose (bottom-right) ───────────────────────────────── -->
    <div
      class="absolute bottom-5 right-5 md:bottom-8 md:right-8 opacity-70 pointer-events-none"
      aria-hidden="true"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="96" height="96" viewBox="0 0 96 96" fill="none">
        <!-- Outer decorative rings -->
        <circle cx="48" cy="48" r="46" stroke="#C4A96A" stroke-width="0.5" opacity="0.6"/>
        <circle cx="48" cy="48" r="43" stroke="#8B6914" stroke-width="0.3" opacity="0.35"/>
        <circle cx="48" cy="48" r="40" stroke="#C4A96A" stroke-width="0.4" opacity="0.5"/>
        <!-- Inner decorative ring -->
        <circle cx="48" cy="48" r="32" stroke="#C4A96A" stroke-width="0.3" opacity="0.4" fill="none"/>

        <!-- Tick marks at 22.5° (between cardinal/ordinal) — 8 positions -->
        <!-- 22.5° --> <line x1="64.0" y1="9.5"  x2="65.1" y2="6.7"  stroke="#C4A96A" stroke-width="0.7" opacity="0.55"/>
        <!-- 67.5° --> <line x1="86.5" y1="32.0" x2="89.3" y2="30.9" stroke="#C4A96A" stroke-width="0.7" opacity="0.55"/>
        <!-- 112.5°--> <line x1="86.5" y1="64.0" x2="89.3" y2="65.1" stroke="#C4A96A" stroke-width="0.7" opacity="0.55"/>
        <!-- 157.5°--> <line x1="64.0" y1="86.5" x2="65.1" y2="89.3" stroke="#C4A96A" stroke-width="0.7" opacity="0.55"/>
        <!-- 202.5°--> <line x1="32.0" y1="86.5" x2="30.9" y2="89.3" stroke="#C4A96A" stroke-width="0.7" opacity="0.55"/>
        <!-- 247.5°--> <line x1="9.5"  y1="64.0" x2="6.7"  y2="65.1" stroke="#C4A96A" stroke-width="0.7" opacity="0.55"/>
        <!-- 292.5°--> <line x1="9.5"  y1="32.0" x2="6.7"  y2="30.9" stroke="#C4A96A" stroke-width="0.7" opacity="0.55"/>
        <!-- 337.5°--> <line x1="32.0" y1="9.5"  x2="30.9" y2="6.7"  stroke="#C4A96A" stroke-width="0.7" opacity="0.55"/>

        <!-- N arrow (dark) -->
        <polygon points="48,5 52.5,45 48,48 43.5,45" fill="#8B6914"/>
        <!-- S arrow (pale) -->
        <polygon points="48,91 52.5,51 48,48 43.5,51" fill="#C4A96A"/>
        <!-- E arrow (dark) -->
        <polygon points="91,48 51,43.5 48,48 51,52.5" fill="#8B6914"/>
        <!-- W arrow (pale) -->
        <polygon points="5,48 45,43.5 48,48 45,52.5" fill="#C4A96A"/>
        <!-- Ordinal points (smaller) -->
        <polygon points="81,15 51.5,45 48,48 52,45" fill="#C4A96A" opacity="0.5"/>
        <polygon points="15,15 45,45 48,48 44,45" fill="#C4A96A" opacity="0.5"/>
        <polygon points="81,81 51.5,51 48,48 52,51" fill="#C4A96A" opacity="0.5"/>
        <polygon points="15,81 45,51 48,48 44,51" fill="#C4A96A" opacity="0.5"/>

        <!-- Decorative dots between inner ring and center -->
        <circle cx="48" cy="22" r="1"   fill="#C4A96A" opacity="0.4"/>
        <circle cx="48" cy="74" r="1"   fill="#C4A96A" opacity="0.4"/>
        <circle cx="74" cy="48" r="1"   fill="#C4A96A" opacity="0.4"/>
        <circle cx="22" cy="48" r="1"   fill="#C4A96A" opacity="0.4"/>

        <!-- Small serif rule below N label -->
        <line x1="44" y1="13" x2="52" y2="13" stroke="#8B6914" stroke-width="0.5" opacity="0.5"/>

        <!-- Center ornament -->
        <circle cx="48" cy="48" r="7"   fill="#8B6914"/>
        <circle cx="48" cy="48" r="4.5" fill="#F5ECD7"/>
        <circle cx="48" cy="48" r="2.5" fill="#8B6914"/>
        <circle cx="48" cy="48" r="1.2" fill="#C4A96A"/>

        <!-- Cardinal labels -->
        <text x="48" y="20" text-anchor="middle" dominant-baseline="middle" font-family="Cinzel,serif" font-size="7.5" fill="#8B6914" font-weight="700">N</text>
        <text x="48" y="80" text-anchor="middle" dominant-baseline="middle" font-family="Cinzel,serif" font-size="7"   fill="#8B6914">S</text>
        <text x="85" y="49" text-anchor="middle" dominant-baseline="middle" font-family="Cinzel,serif" font-size="7"   fill="#8B6914">E</text>
        <text x="11" y="49" text-anchor="middle" dominant-baseline="middle" font-family="Cinzel,serif" font-size="7"   fill="#8B6914">W</text>
      </svg>
    </div>

    <!-- ── Postal stamp accent (bottom-left, decorative) ─────────────── -->
    <div
      class="absolute bottom-5 left-5 md:bottom-8 md:left-8 pointer-events-none"
      aria-hidden="true"
    >
      <img
        src="/accents/postalstamps.avif"
        alt=""
        class="w-16 md:w-20 opacity-35 mix-blend-multiply"
        style="filter: sepia(0.5);"
        loading="eager"
      />
    </div>

    <!-- ── Scale bar (decorative) ─────────────────────────────────────── -->
    <div
      class="absolute pointer-events-none"
      style="bottom: 6%; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 2px; opacity: 0.45;"
      aria-hidden="true"
    >
      <div style="display: flex; align-items: center; gap: 0;">
        <div style="width: 40px; height: 6px; background: #8B6914;"></div>
        <div style="width: 40px; height: 6px; background: #F5ECD7; border: 1px solid #C4A96A;"></div>
        <div style="width: 40px; height: 6px; background: #8B6914;"></div>
      </div>
      <p style="font-family: 'Cinzel', serif; font-size: 0.4rem; letter-spacing: 0.3em; color: #8B6914; text-transform: uppercase;">Scale of Miles</p>
    </div>

  </div>
</Layout>

<style>
  /* Pulsing beacon glow on branch terminus arrowheads */
  @keyframes edge-beacon {
    0%, 100% { opacity: 0.85; }
    50%       { opacity: 0.4;  }
  }
  .branch-arrowhead {
    animation: edge-beacon 2.5s ease-in-out infinite;
  }

  /* Terminus subtitle — smaller Crimson Text italic */
  .branch-subtitle {
    display: block;
    font-family: 'Crimson Text', Georgia, serif;
    font-style: italic;
    font-size: 0.6rem;
    color: var(--color-ink);
    opacity: 0.55;
    letter-spacing: 0.04em;
    margin-top: 1px;
    white-space: nowrap;
  }

  /* South-facing terminus: stack the label vertically beneath the dot */
  .branch-marker--south .branch-body {
    flex-direction: column;
    align-items: flex-start;
  }
</style>

<script>
  // Route draw animation — paths "draw themselves" across the map on page load
  document.addEventListener('DOMContentLoaded', () => {
    function animatePath(id: string, duration: string, delay: string) {
      const path = document.getElementById(id) as SVGPathElement | null;
      if (!path || typeof path.getTotalLength !== 'function') return;
      const len = path.getTotalLength();
      path.style.strokeDasharray = String(len);
      path.style.strokeDashoffset = String(len);
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          path.style.transition = `stroke-dashoffset ${duration} ease-in-out ${delay}`;
          path.style.strokeDashoffset = '0';
        });
      });
    }

    // Main route draws in over 2.5s
    animatePath('route-draw', '2.5s', '0s');
    // Branch paths draw in after main completes + 0.3s buffer
    animatePath('branch-portfolio', '1.2s', '2.8s');
    animatePath('branch-lab', '1.2s', '2.8s');
  });
</script>
