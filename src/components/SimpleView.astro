---
interface Destination {
  label: string;
  desc: string;
  href: string;
  x: string;
  y: string;
  cardSide: string;
  external: boolean;
}
interface Props {
  destinations: Destination[];
}
const { destinations } = Astro.props;

const internalDests = destinations.filter(d => !d.external);
const numerals = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII'];

const externalBranches = [
  {
    label: 'The Portfolio',
    desc: 'Beyond the western reach — a curated record of work.',
    href: 'https://mp0549.github.io/my-portfolio/',
  },
  {
    label: 'The Lab',
    desc: 'Into the experimental deep — prototypes and explorations.',
    href: 'https://mp0549.github.io/lab/',
  },
  ...destinations.filter(d => d.external).map(d => ({ label: d.label, desc: d.desc, href: d.href })),
];
---

<div class="dispatch-view">

  <!-- ── Background layers ──────────────────────────────────────── -->
  <div class="dispatch-bg-map"     aria-hidden="true"></div>
  <div class="dispatch-bg-texture" aria-hidden="true"></div>
  <div class="dispatch-bg-vignette"aria-hidden="true"></div>

  <!-- ── Main document ─────────────────────────────────────────── -->
  <main class="dispatch-scroll">
    <div class="dispatch-doc" id="dispatch-doc">

      <!-- Corner ornaments -->
      <span class="corner corner-tl" aria-hidden="true"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 1L13.2 9.8H22L14.9 14.9L17.2 22L11 17L4.8 22L7.1 14.9L0 9.8H8.8Z" fill="#C4A96A" opacity="0.55"/><circle cx="11" cy="11" r="2.5" fill="#8B6914" opacity="0.5"/></svg></span>
      <span class="corner corner-tr" aria-hidden="true"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 1L13.2 9.8H22L14.9 14.9L17.2 22L11 17L4.8 22L7.1 14.9L0 9.8H8.8Z" fill="#C4A96A" opacity="0.55"/><circle cx="11" cy="11" r="2.5" fill="#8B6914" opacity="0.5"/></svg></span>
      <span class="corner corner-bl" aria-hidden="true"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 1L13.2 9.8H22L14.9 14.9L17.2 22L11 17L4.8 22L7.1 14.9L0 9.8H8.8Z" fill="#C4A96A" opacity="0.55"/><circle cx="11" cy="11" r="2.5" fill="#8B6914" opacity="0.5"/></svg></span>
      <span class="corner corner-br" aria-hidden="true"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 1L13.2 9.8H22L14.9 14.9L17.2 22L11 17L4.8 22L7.1 14.9L0 9.8H8.8Z" fill="#C4A96A" opacity="0.55"/><circle cx="11" cy="11" r="2.5" fill="#8B6914" opacity="0.5"/></svg></span>

      <!-- Faint compass rose watermark inside the document -->
      <div class="dispatch-watermark" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="260" height="260" viewBox="0 0 96 96" fill="none" opacity="0.045">
          <circle cx="48" cy="48" r="46" stroke="#8B6914" stroke-width="0.5"/>
          <circle cx="48" cy="48" r="40" stroke="#8B6914" stroke-width="0.3"/>
          <circle cx="48" cy="48" r="32" stroke="#8B6914" stroke-width="0.3"/>
          <polygon points="48,5 52.5,45 48,48 43.5,45" fill="#8B6914"/>
          <polygon points="48,91 52.5,51 48,48 43.5,51" fill="#8B6914"/>
          <polygon points="91,48 51,43.5 48,48 51,52.5" fill="#8B6914"/>
          <polygon points="5,48 45,43.5 48,48 45,52.5" fill="#8B6914"/>
          <polygon points="81,15 51.5,45 48,48 52,45" fill="#8B6914" opacity="0.5"/>
          <polygon points="15,15 45,45 48,48 44,45" fill="#8B6914" opacity="0.5"/>
          <polygon points="81,81 51.5,51 48,48 52,51" fill="#8B6914" opacity="0.5"/>
          <polygon points="15,81 45,51 48,48 44,51" fill="#8B6914" opacity="0.5"/>
          <circle cx="48" cy="48" r="7" fill="#8B6914"/>
          <circle cx="48" cy="48" r="4" fill="#F5ECD7"/>
          <circle cx="48" cy="48" r="2" fill="#8B6914"/>
          <text x="48" y="20" text-anchor="middle" dominant-baseline="middle" font-family="Cinzel,serif" font-size="7.5" fill="#8B6914" font-weight="700">N</text>
          <text x="48" y="80" text-anchor="middle" dominant-baseline="middle" font-family="Cinzel,serif" font-size="7" fill="#8B6914">S</text>
          <text x="85" y="49" text-anchor="middle" dominant-baseline="middle" font-family="Cinzel,serif" font-size="7" fill="#8B6914">E</text>
          <text x="11" y="49" text-anchor="middle" dominant-baseline="middle" font-family="Cinzel,serif" font-size="7" fill="#8B6914">W</text>
        </svg>
      </div>

      <!-- ── Header ────────────────────────────────────────────── -->
      <header class="dispatch-header dispatch-reveal" style="--delay: 0s;">
        <p class="dispatch-eyebrow">The Archives</p>
        <h1 class="dispatch-name">Maanan Purothi</h1>
        <div class="dispatch-ornament-rule" aria-hidden="true">
          <span class="orule-line"></span>
          <span class="orule-glyph">✦</span>
          <span class="orule-line"></span>
        </div>
        <p class="dispatch-tagline">Mapping the intellectual frontier</p>
        <p class="dispatch-classification" aria-hidden="true">Dispatch No. I &nbsp;·&nbsp; Anno MMXXVI</p>
      </header>

      <!-- ── Section divider ──────────────────────────────────── -->
      <div class="dispatch-divider dispatch-reveal" style="--delay: 0.15s;" aria-hidden="true">
        <span class="div-line"></span>
        <span class="div-label">Known Territories</span>
        <span class="div-line"></span>
      </div>

      <!-- ── Destination entries ───────────────────────────────── -->
      <nav aria-label="Navigation" class="dispatch-entries">
        {internalDests.map(({ label, desc, href }, i) => (
          <a
            href={href}
            class="dispatch-entry dispatch-reveal"
            style={`--delay: ${0.2 + i * 0.07}s;`}
          >
            <span class="entry-numeral" aria-hidden="true">{numerals[i]}</span>
            <span class="entry-rule" aria-hidden="true"></span>
            <span class="entry-body">
              <strong class="entry-label">{label}</strong>
              <span class="entry-desc">{desc}</span>
            </span>
            <span class="entry-arrow" aria-hidden="true">›</span>
          </a>
        ))}
      </nav>

      <!-- ── Beyond the map divider ────────────────────────────── -->
      <div class="dispatch-divider dispatch-reveal" style={`--delay: ${0.2 + internalDests.length * 0.07 + 0.05}s;`} aria-hidden="true">
        <span class="div-line"></span>
        <span class="div-label">Beyond the Map</span>
        <span class="div-line"></span>
      </div>

      <!-- ── External branch entries ───────────────────────────── -->
      <nav aria-label="External links" class="dispatch-entries">
        {externalBranches.map(({ label, desc, href }, i) => (
          <a
            href={href}
            class="dispatch-entry dispatch-entry--external dispatch-reveal"
            style={`--delay: ${0.2 + internalDests.length * 0.07 + 0.15 + i * 0.07}s;`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="entry-numeral entry-numeral--branch" aria-hidden="true">›</span>
            <span class="entry-rule" aria-hidden="true"></span>
            <span class="entry-body">
              <strong class="entry-label">{label}</strong>
              <span class="entry-desc">{desc}</span>
            </span>
            <span class="entry-arrow" aria-hidden="true">↗</span>
          </a>
        ))}
      </nav>

      <!-- ── Footer ────────────────────────────────────────────── -->
      <footer class="dispatch-footer dispatch-reveal" style={`--delay: ${0.2 + internalDests.length * 0.07 + 0.45}s;`} aria-hidden="true">
        <div class="footer-rule"></div>
        <div class="footer-row">
          <span class="footer-coords">48°32'N · 16°17'E</span>
          <img
            src="/accents/postalstamps.avif"
            alt=""
            class="footer-stamp"
            loading="eager"
          />
          <span class="footer-coords">Terra Incognita</span>
        </div>
      </footer>

    </div>
  </main>

</div>

<style>
  /* ── Outer shell ──────────────────────────────────────────────── */
  .dispatch-view {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background: var(--color-parchment, #F5ECD7);
    overflow: auto;
  }

  /* ── Background layers ────────────────────────────────────────── */
  .dispatch-bg-map {
    position: fixed;
    inset: 0;
    background-image: url('/maps/old_cool_map.jpg');
    background-size: cover;
    background-position: center;
    opacity: 0.07;
    filter: sepia(0.6) grayscale(0.3);
    pointer-events: none;
  }

  .dispatch-bg-texture {
    position: fixed;
    inset: 0;
    background-image: url('/textures/parchment_texture1.jpg');
    background-size: 420px 420px;
    background-repeat: repeat;
    mix-blend-mode: multiply;
    opacity: 0.28;
    filter: sepia(0.2) contrast(1.04);
    pointer-events: none;
  }

  .dispatch-bg-vignette {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 80% 75% at center, transparent 20%, rgba(28,18,8,0.28) 100%);
    pointer-events: none;
  }

  /* ── Scroll container ─────────────────────────────────────────── */
  .dispatch-scroll {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 100vh;
    padding: 3rem 1.25rem 3rem;
  }

  /* ── Document frame ───────────────────────────────────────────── */
  .dispatch-doc {
    position: relative;
    width: 100%;
    max-width: 580px;
    padding: 2.75rem 2.5rem 2.25rem;
    background: var(--color-parchment-light, #FAF4E6);
    /* Double border effect */
    border: 1px solid rgba(196,169,106,0.65);
    outline: 4px solid transparent;
    box-shadow:
      inset 0 0 0 6px rgba(245,236,215,0.9),
      inset 0 0 0 7px rgba(196,169,106,0.28),
      0 8px 40px rgba(28,18,8,0.18),
      0 2px 8px rgba(28,18,8,0.1);
  }

  /* Inner border line via pseudo-element */
  .dispatch-doc::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid rgba(196,169,106,0.3);
    pointer-events: none;
  }

  /* ── Corner ornaments ─────────────────────────────────────────── */
  .corner {
    position: absolute;
    width: 22px;
    height: 22px;
    line-height: 0;
  }
  .corner-tl { top: -5px;  left: -5px; }
  .corner-tr { top: -5px;  right: -5px; transform: scaleX(-1); }
  .corner-bl { bottom: -5px; left: -5px;  transform: scaleY(-1); }
  .corner-br { bottom: -5px; right: -5px; transform: scale(-1); }

  /* ── Watermark compass rose ───────────────────────────────────── */
  .dispatch-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    user-select: none;
  }

  /* ── Stagger reveal animation ─────────────────────────────────── */
  @keyframes dispatch-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .dispatch-reveal {
    animation: dispatch-in 0.55s ease-out both;
    animation-delay: var(--delay, 0s);
  }

  /* ── Header ───────────────────────────────────────────────────── */
  .dispatch-header {
    text-align: center;
    margin-bottom: 1.75rem;
  }

  .dispatch-eyebrow {
    font-family: 'Cinzel', serif;
    font-size: 0.55rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--color-gold, #8B6914);
    opacity: 0.7;
    margin-bottom: 0.6rem;
  }

  .dispatch-name {
    font-family: 'Cinzel Decorative', 'Cinzel', serif;
    font-size: clamp(1.8rem, 4.5vw, 2.9rem);
    font-weight: 700;
    color: var(--color-ink, #1C1208);
    letter-spacing: 0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .dispatch-ornament-rule {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 auto 0.85rem;
    max-width: 240px;
  }

  .orule-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-gold-pale, #C4A96A));
  }

  .orule-line + .orule-glyph + .orule-line {
    background: linear-gradient(to left, transparent, var(--color-gold-pale, #C4A96A));
  }

  .orule-glyph {
    font-size: 0.55rem;
    color: var(--color-gold, #8B6914);
    opacity: 0.7;
  }

  .dispatch-tagline {
    font-family: 'Crimson Text', Georgia, serif;
    font-style: italic;
    font-size: 1rem;
    color: var(--color-ink-muted, #7C6A4E);
    letter-spacing: 0.02em;
    margin-bottom: 0.6rem;
  }

  .dispatch-classification {
    font-family: 'Cinzel', serif;
    font-size: 0.45rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-gold, #8B6914);
    opacity: 0.45;
  }

  /* ── Section dividers ─────────────────────────────────────────── */
  .dispatch-divider {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin: 1.4rem 0 1.1rem;
  }

  .div-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(196,169,106,0.5));
  }

  .dispatch-divider .div-line:last-child {
    background: linear-gradient(to left, transparent, rgba(196,169,106,0.5));
  }

  .div-label {
    font-family: 'Cinzel', serif;
    font-size: 0.48rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-gold, #8B6914);
    opacity: 0.65;
    white-space: nowrap;
  }

  /* ── Entry list ───────────────────────────────────────────────── */
  .dispatch-entries {
    display: flex;
    flex-direction: column;
  }

  .dispatch-entry {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0.85rem 0.5rem 0.85rem 0;
    text-decoration: none;
    border-bottom: 1px solid rgba(196,169,106,0.18);
    position: relative;
    transition: background 150ms ease;
    overflow: hidden;
  }

  .dispatch-entry:last-child {
    border-bottom: none;
  }

  .dispatch-entry::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(196,169,106,0.12), transparent 60%);
    opacity: 0;
    transition: opacity 150ms ease;
  }

  .dispatch-entry:hover::before {
    opacity: 1;
  }

  .entry-numeral {
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-gold, #8B6914);
    opacity: 0.65;
    min-width: 2rem;
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  .entry-numeral--branch {
    font-size: 1rem;
    opacity: 0.4;
  }

  .entry-rule {
    width: 1px;
    height: 2.2rem;
    background: linear-gradient(to bottom, transparent, rgba(196,169,106,0.45), transparent);
    margin: 0 0.9rem 0 0.1rem;
    flex-shrink: 0;
  }

  .entry-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .entry-label {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink, #1C1208);
    transition: color 150ms ease;
  }

  .dispatch-entry:hover .entry-label {
    color: var(--color-gold, #8B6914);
  }

  .entry-desc {
    font-family: 'Crimson Text', Georgia, serif;
    font-style: italic;
    font-size: 0.88rem;
    color: var(--color-ink-muted, #7C6A4E);
    line-height: 1.4;
  }

  .entry-arrow {
    font-size: 0.9rem;
    color: var(--color-gold, #8B6914);
    opacity: 0;
    margin-left: 0.6rem;
    flex-shrink: 0;
    transform: translateX(-6px);
    transition: opacity 150ms ease, transform 150ms ease;
  }

  .dispatch-entry:hover .entry-arrow {
    opacity: 0.75;
    transform: translateX(0);
  }

  .dispatch-entry--external .entry-label {
    opacity: 0.7;
  }

  .dispatch-entry--external:hover .entry-label {
    opacity: 1;
  }

  /* ── Footer ───────────────────────────────────────────────────── */
  .dispatch-footer {
    margin-top: 1.6rem;
  }

  .footer-rule {
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(196,169,106,0.45), transparent);
    margin-bottom: 1rem;
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-coords {
    font-family: 'Cinzel', serif;
    font-size: 0.42rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-gold-pale, #C4A96A);
    opacity: 0.55;
  }

  .footer-stamp {
    width: 38px;
    opacity: 0.3;
    filter: sepia(0.5);
    transform: rotate(6deg);
    mix-blend-mode: multiply;
  }

  /* ── Mobile tweaks ────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .dispatch-scroll {
      padding: 1.5rem 0.75rem;
    }
    .dispatch-doc {
      padding: 2rem 1.5rem 1.75rem;
    }
  }
</style>
