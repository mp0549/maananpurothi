---
/**
 * index.astro — Entry point
 * Renders either the fancy Map view or the Simple view depending on
 * the user's toggle preference (persisted in localStorage).
 */
import Layout from '@/layouts/Layout.astro';
import MapView from '@/components/MapView.astro';
import SimpleView from '@/components/SimpleView.astro';

const destinations = [
  {
    label: 'Biographical Notes',
    desc: "The person behind the work. Background, guiding interests, and where I'm headed next.",
    href: `${import.meta.env.BASE_URL}about/`,
    x: '17%',
    y: '57%',
    cardSide: 'right',
    external: false,
  },
  {
    label: 'The Codex',
    desc: 'An archive of expeditions — projects, research, and experiences.',
    href: `${import.meta.env.BASE_URL}codex/`,
    x: '76%',
    y: '44%',
    cardSide: 'left',
    external: false,
  },
  {
    label: 'The Garden',
    desc: 'A space for thinking out loud. Notes, ideas, and works in progress.',
    href: `${import.meta.env.BASE_URL}garden/`,
    x: '27%',
    y: '75%',
    cardSide: 'right',
    external: false,
  },
  {
    label: 'The Workshop',
    desc: "What I'm currently building, reading, and thinking about.",
    href: `${import.meta.env.BASE_URL}now/`,
    x: '70%',
    y: '29%',
    cardSide: 'left',
    external: false,
  },
  {
    label: 'Credentials',
    desc: 'Check out my LinkedIn',
    href: 'https://linkedin.com/in/maananpurothi',
    x: '68%',
    y: '67%',
    cardSide: 'left',
    external: true,
  },
];
---

<!-- Apply stored view before paint to avoid flash -->
<script is:inline>
  (function () {
    var v = localStorage.getItem('homepage-view') || 'simple';
    document.documentElement.setAttribute('data-homepage-view', v);
    // Body starts with h-screen overflow-hidden (map variant).
    // If preference is simple, unlock scrolling before first paint.
    if (v === 'simple') {
      document.body.classList.remove('h-screen', 'overflow-hidden');
      document.body.style.minHeight = '100vh';
    }
  })();
</script>

<Layout
  title="The Archives"
  description="Personal website- A record of work and thought"
  variant="map"
>
  <!-- ── View containers ───────────────────────────────────────────── -->
  <div id="view-map">
    <MapView destinations={destinations} />
  </div>

  <div id="view-simple">
    <SimpleView destinations={destinations} />
  </div>

  <!-- ── Toggle button (fixed, top-right) ─────────────────────────── -->
  <button
    id="view-toggle"
    aria-label="Switch view"
    title="Switch view"
  >
    <!-- Map icon (shown when in simple view — click to go to map) -->
    <span id="toggle-icon-map" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 3.5L5.5 2L10.5 4L15 2.5V12.5L10.5 14L5.5 12L1 13.5V3.5Z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/>
        <path d="M5.5 2V12M10.5 4V14" stroke="currentColor" stroke-width="1.1"/>
      </svg>
      <span>Map</span>
    </span>
    <!-- List icon (shown when in map view — click to go to simple) -->
    <span id="toggle-icon-list" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="4" y1="4.5" x2="13" y2="4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        <line x1="4" y1="8"   x2="13" y2="8"   stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        <line x1="4" y1="11.5" x2="13" y2="11.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        <circle cx="2" cy="4.5"  r="0.8" fill="currentColor"/>
        <circle cx="2" cy="8"    r="0.8" fill="currentColor"/>
        <circle cx="2" cy="11.5" r="0.8" fill="currentColor"/>
      </svg>
      <span>Simple</span>
    </span>
  </button>

</Layout>

<style>
  /* ── Initial hide both views — JS will reveal the correct one ───── */
  #view-map,
  #view-simple {
    display: none;
  }

  /* ── Show correct view based on data attribute set by inline script  */
  :global([data-homepage-view="map"])    #view-map    { display: block; }
  :global([data-homepage-view="simple"]) #view-simple { display: block; }

  /* ── Toggle button ──────────────────────────────────────────────── */
  #view-toggle {
    position: fixed;
    top: 1.1rem;
    right: 1.1rem;
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.38rem 0.75rem;
    background: var(--color-parchment-light, #FAF4E6);
    border: 1px solid var(--color-gold-pale, #C4A96A);
    color: var(--color-gold, #8B6914);
    font-family: 'Cinzel', serif;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    opacity: 0.88;
    transition: opacity 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
    box-shadow: 0 1px 4px rgba(28,18,8,0.1);
  }

  #view-toggle:hover {
    opacity: 1;
    border-color: var(--color-gold, #8B6914);
    box-shadow: 0 2px 8px rgba(28,18,8,0.15);
  }

  #view-toggle span {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  /* Show/hide toggle icon labels based on current view */
  :global([data-homepage-view="map"])    #toggle-icon-map  { display: none; }
  :global([data-homepage-view="map"])    #toggle-icon-list { display: flex; }
  :global([data-homepage-view="simple"]) #toggle-icon-list { display: none; }
  :global([data-homepage-view="simple"]) #toggle-icon-map  { display: flex; }
</style>

<script>
  const btn = document.getElementById('view-toggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-homepage-view') || 'map';
      const next = current === 'map' ? 'simple' : 'map';
      document.documentElement.setAttribute('data-homepage-view', next);
      localStorage.setItem('homepage-view', next);

      // Sync body scroll classes with the active view
      if (next === 'simple') {
        document.body.classList.remove('h-screen', 'overflow-hidden');
        document.body.style.minHeight = '100vh';
      } else {
        document.body.classList.add('h-screen', 'overflow-hidden');
        document.body.style.minHeight = '';
      }
    });
  }
</script>
